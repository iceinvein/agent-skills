{
  "name": "dependency-direction-auditor",
  "version": "1.0.0",
  "description": "Martin-inspired dependency direction analysis — trace imports across layers, classify violations by severity, recommend inversion",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/dependency-direction-auditor/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/dependency-direction-auditor.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/dependency-direction-auditor.md"
    }
  }
}
