{
  "name": "cqs-auditor",
  "version": "1.0.0",
  "description": "Meyer-inspired Command-Query Separation — classify functions as commands or queries, detect mixed violations, separate side effects from return values",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/cqs-auditor/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/cqs-auditor.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/cqs-auditor.md"
    }
  }
}
