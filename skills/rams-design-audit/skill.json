{
  "name": "rams-design-audit",
  "version": "1.0.0",
  "description": "Dieter Rams-inspired design audit — every visual element must earn its presence, less but better, clarity through restraint",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/rams-design-audit/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/rams-design-audit.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/rams-design-audit.md"
    }
  }
}
