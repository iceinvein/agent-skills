{
  "name": "bounded-context-auditor",
  "version": "1.0.0",
  "description": "Evans-inspired bounded context analysis — detect linguistic fractures, draw context maps, identify leaking language and shared model pollution",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/bounded-context-auditor/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/bounded-context-auditor.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/bounded-context-auditor.md"
    }
  }
}
