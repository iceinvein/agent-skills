{
  "name": "cognitive-load-auditor",
  "version": "1.0.0",
  "description": "Jeff Johnson-inspired cognitive load analysis — evaluate UI against Miller's Law, Hick's Law, Fitts's Law, and working memory limits",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/cognitive-load-auditor/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/cognitive-load-auditor.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/cognitive-load-auditor.md"
    }
  }
}
