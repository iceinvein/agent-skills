{
  "name": "cohesion-analyzer",
  "version": "1.0.0",
  "description": "Constantine & Yourdon-inspired cohesion analysis — classify module focus on the 7-level spectrum, find split lines, reduce mixed responsibilities",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/cohesion-analyzer/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/cohesion-analyzer.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/cohesion-analyzer.md"
    }
  }
}
