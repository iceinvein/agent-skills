{
  "name": "improve-my-codebase",
  "version": "1.0.0",
  "description": "Orchestrator skill that runs every applicable audit skill in parallel and produces a prioritized, convergence-ranked improvement report",
  "author": "iceinvein",
  "type": "prompt",
  "tools": ["claude", "cursor", "codex", "gemini"],
  "files": {
    "prompt": "SKILL.md"
  },
  "install": {
    "claude": {
      "prompt": ".claude/skills/improve-my-codebase/SKILL.md"
    },
    "cursor": {
      "prompt": ".cursor/rules/improve-my-codebase.mdc"
    },
    "codex": {
      "prompt": "AGENTS.md",
      "append": true
    },
    "gemini": {
      "prompt": ".gemini/skills/improve-my-codebase.md"
    }
  }
}
