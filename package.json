{
  "name": "@iceinvein/agent-skills",
  "version": "0.1.21",
  "description": "Install agent skills into AI coding tools",
  "author": "iceinvein",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agent-skills": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target bun",
    "test": "bun test",
    "dev": "bun run src/cli/index.ts",
    "skill:bump": "bun run src/cli/index.ts bump",
    "skill:bump:all": "bun run src/cli/index.ts bump --all",
    "skill:bump:check": "bun run src/cli/index.ts bump --all --dry-run",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "claude",
    "cursor",
    "codex",
    "gemini",
    "mcp",
    "cli",
    "prompt-engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iceinvein/agent-skills"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "bun-types": "^1.3.11"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2"
  }
}
